# AI Configuration
DEEPSEEK_MODEL=deepseek-chat  # Can be updated to deepseek-v3.2 or deepseek-v3.2-speciale
AI_CACHE_ENABLED=True
AI_MAX_TOKENS_RESPONSE=1000
AI_MAX_TOKENS_ANALYSIS=500
AI_TEMPERATURE_LOW=0.1
AI_TEMPERATURE_HIGH=0.7

# Existing configuration...
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DATABASE_URL=your_database_url_here
REDIS_URL=your_redis_url_here
TELEGRAM_TOKEN=your_telegram_token_here
WEBHOOK_URL=your_webhook_url_here
WEB_APP_URL=your_web_app_url_here
ADMIN_SECRET=your_admin_secret_here