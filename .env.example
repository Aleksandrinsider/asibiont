# === ОБЯЗАТЕЛЬНЫЕ ПЕРЕМЕННЫЕ ===

# Telegram Bot Configuration
TELEGRAM_TOKEN=your-telegram-bot-token-here
TELEGRAM_BOT_USERNAME=Asibiont_bot

# Database Configuration (PostgreSQL for production, SQLite for local)
DATABASE_URL=postgresql://user:password@host:port/database
DATABASE_PUBLIC_URL=postgresql://user:password@host:port/database

# DeepSeek AI Configuration
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-reasoner

# Redis Configuration (required for production)
REDIS_URL=redis://default:password@host:port

# Security
ENCRYPTION_KEY=your-32-byte-encryption-key-here
SESSION_SECRET=your-session-secret-key-here
ADMIN_SECRET=your-admin-secret-key

# Payment System (Yookassa)
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key
YOOKASSA_WEBHOOK_URL=https://your-domain.com/yookassa-webhook

# === ОПЦИОНАЛЬНЫЕ ПЕРЕМЕННЫЕ ===

# Application Settings
PORT=8080
LOCAL=False
FREE_ACCESS_MODE=False
USE_OPTIMIZED_PROMPT=True
CURRENT_DATE=

# Web Configuration
WEBHOOK_URL=https://your-domain.com/webhook
WEB_APP_URL=https://asibiont.ru

# AI Optimization
AI_CACHE_ENABLED=False
AI_MAX_TOKENS_RESPONSE=1000
AI_MAX_TOKENS_ANALYSIS=500
AI_TEMPERATURE_LOW=0.1
AI_TEMPERATURE_HIGH=0.7

# Reminder Service Configuration
DAILY_REPORT_HOUR=22
PROACTIVE_CHECK_INTERVAL_MINUTES=30
OVERDUE_CHECK_INTERVAL_MINUTES=15
PROACTIVE_CHECK_AHEAD_MINUTES=60
LAST_INTERACTION_THRESHOLD_MINUTES=15
DEFAULT_TASK_REMINDER_HOURS=1

# Proactive Messaging Restrictions
PROACTIVE_NO_SEND_START_HOUR=22
PROACTIVE_NO_SEND_END_HOUR=10
PROACTIVE_CHECK_INTERVAL_WITH_TASKS_MINUTES=30
PROACTIVE_CHECK_INTERVAL_NO_TASKS_MINUTES=60
